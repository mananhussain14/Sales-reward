# SalesReward — environment template.
#
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored; this
# file is committed and MUST NOT contain real secrets. Every value below is a
# placeholder.

# --- Supabase (server + browser) ---------------------------------------------
# The project URL and the PUBLISHABLE (anon) key are safe to expose to the browser
# and are inlined into the client bundle by Next.js.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# The SERVICE-ROLE key bypasses Row Level Security. SERVER-ONLY — it is never
# NEXT_PUBLIC_ and must never reach browser code. Used only by the server-side admin
# client for the invitation preparation/finalization RPCs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Application origin -------------------------------------------------------
# The absolute origin of THIS app, used to build invitation accept links. Must be
# https except on a loopback dev host (http://localhost:3000 is allowed).
APP_ORIGIN=http://localhost:3000

# --- Retailer Owner invitations (new-user flow) -------------------------------
# Enables the original inviteUserByEmail (new-account) invitation flow. The ONLY
# value that enables it is the exact string "true"; anything else (or unset) is
# DISABLED — the feature fails closed.
RETAILER_OWNER_INVITATIONS_ENABLED=false

# --- Retailer Owner invitations (existing-user flow) --------------------------
# Enables the application-owned-token flow for inviting an address that ALREADY has
# a SalesReward account. Separate rollout switch from the new-user flag above; it
# adds the Resend email dependency below. Enabled ONLY by the exact string "true".
RETAILER_OWNER_EXISTING_USER_INVITATIONS_ENABLED=false

# --- Retailer STAFF invitations ----------------------------------------------
# Enables SENDING (and re-sending) Retailer staff invitations — the Retailer Owner
# invites a RETAILER_MANAGER or SALES_STAFF member. Like the flow above it uses an
# application-owned token and the Resend dependency below, so it has its own
# rollout switch. Enabled ONLY by the exact string "true"; anything else is
# DISABLED.
#
# Deliberately does NOT gate: reading the staff roster, reading the invitation
# list, REVOKING an invitation, or ACCEPTING one. A kill switch must not be able to
# strand a recipient mid-flow or stop an owner withdrawing an invitation.
RETAILER_STAFF_INVITATIONS_ENABLED=false

# Enables the "create an account" option on the staff invitation acceptance page,
# for an invited person who has no SalesReward account yet. Enabled ONLY by the
# exact string "true".
#
# SETTING THIS ALONE DOES NOTHING. The hosted Supabase project used by this
# repository currently has signups DISABLED at the Auth server, so signUp() is
# refused no matter what this flag says. Turning the feature on requires all three
# of the following in the Supabase project (Authentication settings) — none of
# which is a code change:
#   1. Enable email signup ("Allow new users to sign up").
#   2. KEEP email confirmation ENABLED. Acceptance requires a CONFIRMED address
#      that exactly matches the invitation, so auto-confirm would let anyone claim
#      an invited address by registering it.
#   3. Add the invitation acceptance URL to the allowed redirect URLs, so the
#      confirmation email can return the visitor to the flow:
#         <APP_ORIGIN>/invitations/staff
#      (the invitation link itself, <APP_ORIGIN>/invitations/staff/enter, is an
#      ordinary app route and needs no Auth allow-listing).
# Until those are in place, leave this false: the page then offers sign-in only and
# tells an account-less recipient to ask their inviter, rather than showing a
# button that cannot work.
RETAILER_STAFF_REGISTRATION_ENABLED=false

# Resend (https://resend.com) — sends the application-owned invitation emails via
# its REST API, for BOTH the existing-user Retailer Owner flow and the Retailer
# staff flow. SERVER-ONLY. RESEND_FROM must be a verified sender on your Resend
# account (e.g. "SalesReward <no-reply@yourdomain.com>"). Required only when one of
# those flows is enabled.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=SalesReward <no-reply@yourdomain.com>
