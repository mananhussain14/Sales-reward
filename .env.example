# SalesReward — environment template.
#
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored; this
# file is committed and MUST NOT contain real secrets. Every value below is a
# placeholder.

# --- Supabase (server + browser) ---------------------------------------------
# The project URL and the PUBLISHABLE (anon) key are safe to expose to the browser
# and are inlined into the client bundle by Next.js.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# The SERVICE-ROLE key bypasses Row Level Security. SERVER-ONLY — it is never
# NEXT_PUBLIC_ and must never reach browser code. Used only by the server-side admin
# client for the invitation preparation/finalization RPCs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Application origin -------------------------------------------------------
# The absolute origin of THIS app, used to build invitation accept links. Must be
# https except on a loopback dev host (http://localhost:3000 is allowed).
APP_ORIGIN=http://localhost:3000

# --- Retailer Owner invitations (new-user flow) -------------------------------
# Enables the original inviteUserByEmail (new-account) invitation flow. The ONLY
# value that enables it is the exact string "true"; anything else (or unset) is
# DISABLED — the feature fails closed.
RETAILER_OWNER_INVITATIONS_ENABLED=false

# --- Retailer Owner invitations (existing-user flow) --------------------------
# Enables the application-owned-token flow for inviting an address that ALREADY has
# a SalesReward account. Separate rollout switch from the new-user flag above; it
# adds the Resend email dependency below. Enabled ONLY by the exact string "true".
RETAILER_OWNER_EXISTING_USER_INVITATIONS_ENABLED=false

# Resend (https://resend.com) — sends the existing-user invitation email via its
# REST API. SERVER-ONLY. RESEND_FROM must be a verified sender on your Resend
# account (e.g. "SalesReward <no-reply@yourdomain.com>"). Required only when the
# existing-user flow above is enabled.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=SalesReward <no-reply@yourdomain.com>
